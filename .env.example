# F1 Podium Predictor — Environment Configuration

# Database
DB_PATH=data/db/race_history.db

# FastF1 cache directory
FASTF1_CACHE_DIR=data/cache

# OpenF1 API (no key required for historical)
OPENF1_BASE_URL=https://api.openf1.org/v1

# Jolpica API (Ergast replacement, no key required)
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# Open-Meteo API (no key required)
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# Model settings
MODEL_DIR=models/artifacts
LOG_LEVEL=INFO
